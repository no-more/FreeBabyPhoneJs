{
	"name": "free-baby-phone-js",
	"version": "1.0.0",
	"private": true,
	"description": "WebRTC-based babyphone PWA with QR-code signalling (no server required).",
	"scripts": {
		"clean": "rimraf dist sw.js",
		"typecheck": "tsc --noEmit",
		"build": "npm run clean && tsc && node scripts/post-build.mjs",
		"watch": "tsc --watch",
		"lint": "eslint \"src/**/*.ts\"",
		"lint:fix": "eslint \"src/**/*.ts\" --fix",
		"serve": "npx --yes serve .",
		"dev": "npm run build && npm run serve"
	},
	"dependencies": {
		"qrcode-generator": "^1.4.4",
		"qr-scanner": "^1.4.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.12.0",
		"@typescript-eslint/eslint-plugin": "^8.8.0",
		"@typescript-eslint/parser": "^8.8.0",
		"eslint": "^9.12.0",
		"rimraf": "^6.0.1",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.8.0"
	}
}